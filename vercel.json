{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "git": {
    "deploymentEnabled": {
      "pages-test": false
    }
  },
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    },
    "api/narrate-observation.mjs": {
      "maxDuration": 30
    },
    "api/interpret-transfer.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/narrate-observation", "destination": "/api/narrate-observation.mjs" },
    { "source": "/api/interpret-transfer", "destination": "/api/interpret-transfer.mjs" },
    { "source": "/api/:path*", "destination": "/api/index.mjs" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "same-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://zstgpnwnwmeifgmyeqtz.supabase.co; base-uri 'none'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}